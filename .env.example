# Supabase — copy to .env.local and fill in real values (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser / NEXT_PUBLIC_*.
# Required for notifications + the reminder cron (reads across all bookings).
SUPABASE_SERVICE_ROLE_KEY=

# --- Notifications (Step 7) — all optional; missing keys degrade gracefully ---

# Email via Resend (https://resend.com). RESEND_FROM must be a verified sender.
RESEND_API_KEY=
RESEND_FROM=Майстор24 <no-reply@example.com>

# SMS/Viber via a generic HTTP provider endpoint (pluggable).
SMS_PROVIDER_URL=
SMS_API_KEY=

# Protects /api/cron/reminders. Vercel Cron sends it as a Bearer token.
CRON_SECRET=

# Base URL used to build review links in notifications (e.g. https://maistor24.bg).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: overrides the secret used to sign review tokens.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset.
REVIEW_TOKEN_SECRET=
